.DS_Store

# Python cache and local virtualenvs
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Local test scratch space
tests/tmp/

# Machine-local scheduler config
.env.local
.schedule.local
.scheduler/

# Local user profile data
/profile/
/cv.md
*.pdf

# Generated logs
logs/

# Local user track data
tracks/*
!tracks/test_workflow/
!tracks/test_workflow/**
tracks/*/digests/

# Generated artifacts and digests
artifacts/

# Generated local state
shared/seen_jobs.md
shared/ranked_jobs/*
!shared/ranked_jobs/test_workflow.json
ranked_overview.md

# Keep test workflow fixtures
!artifacts/digests
artifacts/digests/*
!artifacts/digests/test_workflow
!artifacts/discovery
artifacts/discovery/*
!artifacts/discovery/test_workflow
!tracks/test_workflow/ranked_overview.md
