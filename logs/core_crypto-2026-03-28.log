import json, pathlib, re
artifact = json.loads(pathlib.Path('artifacts/discovery/core_crypto/2026-03-28.json').read_text())
seen_urls = {line.split(' | ')[4].strip() for line in pathlib.Path('shared/seen_jobs.md').read_text().splitlines() if line and not line.startswith('#') and len(line.split(' | ')) >= 5}
interesting = re.compile(r'crypt|privacy|identity|auth|encrypt|quantum|pqc|mpc|homomorphic|fhe|zero-knowledge|zk|smart ?card|wallet|embedded security|security research|protocol', re.I)
rows = {}
for src in artifact['sources']:
    if not src.get('due_today'):
        continue
    for c in src.get('candidates', []):
        url = c.get('url') or ''
        if not url or url in seen_urls:
            continue
        title = c.get('title','')
        terms = ' '.join(c.get('matched_terms', []))
        text = f\"{title} {terms}\"
        if not interesting.search(text):
            continue
        rows[url] = {
            'source': src['source'],
            'employer': c.get('employer','unknown'),
            'title': title,
            'location': c.get('location','unknown'),
            'matched_terms': ','.join(c.get('matched_terms', [])) or '-',
            'url': url,
            'notes': c.get('notes','')
        }
for r in sorted(rows.values(), key=lambda x: (x['source'], x['title'].lower())):
    print('\\t'.join([r['source'], r['employer'], r['title'], r['location'], r['matched_terms'], r['url'], r['notes']]))
