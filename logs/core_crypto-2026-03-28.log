/bin/zsh -lc "python3 - <<'PY'
import json, pathlib
artifact = json.loads(pathlib.Path('artifacts/discovery/core_crypto/2026-03-28.json').read_text())
seen_urls = set()
seen_titles = set()
for line in pathlib.Path('shared/seen_jobs.md').read_text().splitlines():
    if not line or line.startswith('#'):
        continue
    parts = [p.strip() for p in line.split(' | ')]
    if len(parts) >= 5:
        _, employer, title, location, url = parts[:5]
        seen_urls.add(url)
        seen_titles.add((employer.lower(), title.lower(), location.lower()))
rows = []
for src in artifact['sources']:
    if not src.get('due_today'):
        continue
    for c in src.get('candidates', []):
        employer = c.get('employer','unknown')
        title = c.get('title','unknown')
        location = c.get('location','unknown')
        url = c.get('url','')
        dup_url = url in seen_urls if url else False
        dup_triplet = (employer.lower(), title.lower(), location.lower()) in seen_titles
        rows.append({
            'source': src['source'],
            'employer': employer,
            'title': title,
            'location': location,
            'url': url,
            'dup_url': dup_url,
            'dup_triplet': dup_triplet,
            'matched_terms': c.get('matched_terms', []),
            'notes': c.get('notes','')
        })
print('TOTAL', len(rows))
print('NON_DUP_URL', sum(not r['dup_url'] for r in rows))
print('NON_DUP_BOTH', sum((not r['dup_url']) and (not r['dup_triplet']) for r in rows))
for r in rows:
    if r['dup_url'] or r['dup_triplet']:
        continue
    print('\\t'.join([
        r['source'], r['employer'], r['title'], r['location'], ','.join(r['matched_terms']) or '-', r['url'], r['notes']
    ]))
