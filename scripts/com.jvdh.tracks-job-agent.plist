<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.jvdh.tracks-job-agent</string>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/zsh</string>
      <string>-lc</string>
      <string><![CDATA[
set -euo pipefail

ROOT="/Users/jvdh/Documents/job-agent"
STATUS=0

/bin/bash "$ROOT/scripts/run_track.sh" --track core_crypto || STATUS=$?
/bin/bash "$ROOT/scripts/run_track.sh" --track postdoc_crypto || STATUS=$?
/bin/bash "$ROOT/scripts/run_track.sh" --track public_service || STATUS=$?
/bin/bash "$ROOT/scripts/run_track.sh" --track alignment_tech || STATUS=$?

exit "$STATUS"
      ]]></string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
      <key>HOME</key>
      <string>/Users/jvdh</string>
      <key>PATH</key>
      <string>/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <key>WorkingDirectory</key>
    <string>/Users/jvdh</string>

    <key>StartCalendarInterval</key>
    <dict>
      <key>Hour</key>
      <integer>8</integer>
      <key>Minute</key>
      <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/jvdh/Documents/job-agent/logs/launchd-tracks.out</string>

    <key>StandardErrorPath</key>
    <string>/Users/jvdh/Documents/job-agent/logs/launchd-tracks.err</string>
  </dict>
</plist>
